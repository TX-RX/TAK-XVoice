<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service descriptor for SamsungActiveKeyAccessibilityService.

    This service exists for one purpose only: intercepting the Samsung
    Active Key (keyCode 1015) via onKeyEvent so PTT works while ATAK is
    in the background on Samsung ruggedized hardware (Tab Active5,
    XCover6 Pro / 7, Tab Active4 Pro, Tab Active3).

    Scope is intentionally the narrowest possible:
      - accessibilityEventTypes="typeWindowStateChanged" → nominal
        subscription. AAPT rejects both "typeNone" and "0" as
        incompatible with the flag attribute; a single benign type
        satisfies the schema. The service's onAccessibilityEvent
        implementation ignores every dispatched event — only
        onKeyEvent does actual work — so subscribing to
        typeWindowStateChanged has no runtime cost or privacy
        implication beyond a no-op callback that returns
        immediately.
      - canRetrieveWindowContent="false"    → never reads screen content
      - canRequestFilterKeyEvents="true"    → REQUIRED meta-attribute
        that grants the service permission to declare
        accessibilityFlags="flagRequestFilterKeyEvents". Field-verified
        2026-07-14 on SM-X308U: without this attribute the flag is
        silently ignored and onKeyEvent is never dispatched, even
        though the service is bound and shows requestFilterKeyEvents=true
        in dumpsys accessibility. This is the load-bearing line —
        without it there is no background PTT.
      - flagRequestFilterKeyEvents          → grants onKeyEvent

    The service does NOT observe typed text, viewed windows, app data,
    or any other accessibility information.  Only KEY_CODE_PTT (1015)
    is ever acted on; all other keycodes are passed through untouched.
-->
<!--
    android:accessibilityFeedbackType="feedbackGeneric" is required even
    though this service produces no feedback: a service declared with a
    zero feedback type can be excluded from
    AccessibilityManager.getEnabledAccessibilityServiceList(FEEDBACK_ALL_MASK),
    which is exactly the query XvMapComponent uses to decide whether the
    "background Active Key" settings row reads enabled. Without it the row
    would show disabled even when the operator has turned the service on.
    android:notificationTimeout="0" is the standard no-throttle value.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRequestFilterKeyEvents"
    android:canRequestFilterKeyEvents="true"
    android:canRetrieveWindowContent="false"
    android:description="@string/xv_accessibility_service_description"
    android:notificationTimeout="0"
    android:settingsActivity="com.atakmap.android.xv.plugin.PermissionRequestActivity"/>
