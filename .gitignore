# ---------- Reverse-engineering workspace ----------
# Decompiled Vx is for research only; never commit the third-party APK,
# its decompiled source, or analysis notes derived from it. Whole
# `research/` is opaque to git by default. To intentionally include
# something from research/, use `git add -f <path>` after manual review.
research/
tools/

# ---------- IDE ----------
.idea/
*.iml
.vscode/
*.iws
*.ipr
local.properties

# ---------- Android ----------
captures/
.externalNativeBuild/
.cxx/

# ---------- Secrets / signing ----------
*.jks
*.keystore
keystore.properties
signing.properties
app/atak_keystore

# ---------- Local per-clone script config ----------
# scripts/config.json is per-operator (real ATAK server hostnames,
# device-specific ATAK APK paths, callsign redaction lists). Only the
# committed config.example.json travels with the repo.
scripts/config.json

# ---------- ATAK SDK (vendored, do not commit) ----------
app/libs/main.jar
app/libs/*.jar

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- Logs ----------
*.log
# Ignore the entire top-level logs/ directory even when its contents
# don't end in .log (e.g. dumpsys snapshots, raw audio captures, JSON
# diagnostics). Field-capture material; never committed.
/logs/
# Root-level logcat dumps written by agent/adb sessions (e.g.
# logcat_<serial>.txt). These may contain device identifiers, server
# hostnames, and operator callsigns. Always excluded; move them to
# .logs/ for local retention.
/logcat_*.txt
hs_err_pid*
# Scratch dir for logcat dumps + ad-hoc diagnostics (created by
# agent sessions to keep large/noisy artifacts out of the project
# root). Never committed.
.tmp/
# Persisted diagnostic captures (logcat dumps, audio/dumpsys snapshots,
# TPP return APKs, post-mortem analyses). Sometimes contains sensitive
# device identifiers and credentials snapshotted from `dumpsys`, so
# always excluded. Per-day subdirs (e.g. .logs/2026-05-18-pixel/).
.logs/
# Same rationale as .logs/ — ad-hoc field captures keyed by date that
# routinely run hundreds of MB per session. Per-day subdirs (e.g.
# diagnostics/2026-06-04-tpt-routing/). Never committed; the tpp
# archive task also excludes them so they don't ship to the build
# pipeline.
diagnostics/
# Peer-side audio captures pulled off Mumble desktop / OBS / recorder
# rigs for AEC / NS / cold-SCO tuning. File names embed the real TAK
# server hostname + operator callsign (e.g.
# Mumble-<timestamp>-<server>-<callsign>VS1.mp3) — those are exactly
# the sensitive-content categories the repo policy forbids in commits,
# so the whole folder is opaque to git and never surfaced. Store all
# peer recordings under .audio/<date-slug>/ so day-of-session
# processing has a predictable location.
.audio/

# ---------- Kotlin compiler caches ----------
.kotlin/

# ---------- Local agent / tooling settings ----------
.claude/
